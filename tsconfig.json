{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["vitest/globals", "@types/bun"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@f/*": ["src/features/*"]
    }
  },
  "include": ["src"]
}
