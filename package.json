{
  "name": "my-solid-app",
  "version": "0.0.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "vitest": {
    "test": {
      "environment": "jsdom",
      "globals": true,
      "transformMode": {
        "web": [
          "/\\.[jt]sx?$/"
        ]
      },
      "include": [
        "src/**/*.{test,spec}.{ts,tsx}"
      ]
    }
  },
  "eslintConfig": {
    "extends": [
      "solid"
    ]
  },
  "bun": {
    "watch": [
      "src/**/*.{ts,tsx}"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/bun": "latest",
    "@vitest/ui": "^4.1.5",
    "eslint": "^10.3.0",
    "jsdom": "^29.1.1",
    "solid-testing-library": "^0.5.1",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.10",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "typescript": "5"
  },
  "dependencies": {
    "@ark-ui/solid": "^5.36.2",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/solid-form": "^1.29.1",
    "@tanstack/solid-query": "^5.100.7",
    "@tanstack/solid-router": "^1.169.1",
    "@tanstack/solid-table": "^8.21.3",
    "arktype": "^2.2.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "libphonenumber-js": "^1.12.42",
    "lucide-solid": "^1.14.0",
    "solid-js": "^1.9.12",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2"
  }
}
